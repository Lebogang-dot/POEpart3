        <Window x:Class="CyberSecurityAwarenessChatbot.ProcessUserMessage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSecurity Awareness Chatbot"
        Height="750"
        Width="1250"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#FFEFF4F8">

    <Grid>
        
        <Grid.RowDefinitions>

            <RowDefinition Height="70"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="35"/>

        </Grid.RowDefinitions>

        
        <Border Grid.Row="0"
                Background="#0D47A1">

            <Grid>

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="250"/>

                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="20,0">

                    <TextBlock
                        FontSize="28"
                        Foreground="White"
                        FontWeight="Bold"
                        Text="🛡"/>

                    <TextBlock
                        Margin="10,0,0,0"
                        FontSize="26"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="CyberSecurity Awareness Chatbot"/>

                </StackPanel>

                <StackPanel Grid.Column="1"VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="0,0,20,0">

                    <TextBlock
                        Name="txtDate"
                        FontSize="15"
                        Foreground="White"
                        HorizontalAlignment="Right"/>

                    <TextBlock
                        Text="Status : Ready"
                        FontSize="14"
                        Foreground="White"
                        HorizontalAlignment="Right"/>

                </StackPanel>

            </Grid>

        </Border>

        

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="230"/>

                <ColumnDefinition Width="*"/>

            </Grid.ColumnDefinitions>

           

            <Border
                Grid.Column="0"
                Background="#263238">

                <StackPanel>

                    <TextBlock
                        Text="Navigation"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Margin="15"/>

                    <Button
                        Name="btnHome"
                        Height="45"
                        Margin="15,5"
                        Content="🏠 Home"/>

                    <Button
                        Name="btnChat"
                        Height="45"
                        Margin="15,5"
                        Content="🤖 Chatbot"/>

                    <Button
                        Name="btnReminder"
                        Height="45"
                        Margin="15,5"
                        Content="📋 Task Manager"/>

                    <Button
                        Name="btnQuiz"
                        Height="45"
                        Margin="15,5"
                        Content=" Cyber Quiz"/>

                    <Button
                        Name="btnActivity"
                        Height="45"
                        Margin="15,5"
                        Content=" Activity Log"/>

                    <Button
                        Name="btnAbout"
                        Height="45"
                        Margin="15,5"
                        Content="ℹ About"/>

                    <Separator Margin="15"/>

                    <TextBlock
                        Margin="15"
                        Foreground="White"
                        FontSize="16"
                        Text="Quick Commands"/>

                    <TextBlock
                        Margin="15,5"
                        Foreground="White"
                        Text="• Start Quiz"/>

                    <TextBlock
                        Margin="15,5"
                        Foreground="White"
                        Text="• Add Reminder"/>

                    <TextBlock
                        Margin="15,5"
                        Foreground="White"
                        Text="• Show Activity Log"/>

                </StackPanel>

            </Border>

           

            <Grid Grid.Column="1"
                  Margin="15">

                <Grid.RowDefinitions>

                    <RowDefinition Height="*"/>

                    <RowDefinition Height="90"/>

                </Grid.RowDefinitions>

                <!-- CHAT AREA -->

                <GroupBox
                    Header="Chat Window"
                    FontSize="18"
                    FontWeight="Bold">

                    <RichTextBox
                        Name="rtbChat"
                        Margin="10"
                        VerticalScrollBarVisibility="Auto"
                        IsReadOnly="True"/>

                </GroupBox>

                <!-- INPUT AREA -->

                <Grid
                    Grid.Row="1">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="150"/>

                    </Grid.ColumnDefinitions>

                    <TextBox
                        Name="txtUserInput"
                        FontSize="18"
                        Margin="0,15,10,15"
                        VerticalContentAlignment="Center"/>

                    <Button
                        Grid.Column="1"
                        Name="btnSend"
                        FontSize="18"
                        FontWeight="Bold"
                        Content="Send"
                        Margin="0,15"
                        Background="#2196F3"
                        Foreground="White"/>

                </Grid>

            </Grid>

        </Grid>
        <!-- STATUS BAR -->

        <StatusBar Grid.Row="2"
                   Background="#0D47A1"
                   Foreground="White">

            <StatusBarItem>
                <TextBlock Name="txtConnectionStatus"
                           Text="Database: Disconnected"/>
            </StatusBarItem>

            <Separator/>

            <StatusBarItem>
                <TextBlock Name="txtCurrentUser"
                           Text="User: Guest"/>
            </StatusBarItem>

            <Separator/>

            <StatusBarItem>
                <TextBlock Name="txtApplicationStatus"
                           Text="Application Ready"/>
            </StatusBarItem>

        </StatusBar>

    </Grid>

    <!-- ===========================
         APPLICATION STYLES
         =========================== -->

    <Window.Resources>

        <!-- Default Button Style -->
        <Style TargetType="Button">

            <Setter Property="Background"
                    Value="#1976D2"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="FontSize"
                    Value="16"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="Padding"
                    Value="10"/>

            <Setter Property="Margin"
                    Value="5"/>

        </Style>

        <!-- Mouse Hover -->
        <Style TargetType="Button">
            <Style.Triggers>

                <Trigger Property="IsMouseOver"
                         Value="True">

                    <Setter Property="Background"
                            Value="#1565C0"/>

                </Trigger>

            </Style.Triggers>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">

            <Setter Property="FontSize"
                    Value="17"/>

            <Setter Property="Padding"
                    Value="8"/>

            <Setter Property="BorderBrush"
                    Value="Gray"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

        </Style>

        <!-- GroupBox -->
        <Style TargetType="GroupBox">

            <Setter Property="FontSize"
                    Value="18"/>

            <Setter Property="FontWeight"
                    Value="Bold"/>

            <Setter Property="Margin"
                    Value="5"/>

        </Style>

    </Window.Resources>

</Window>
