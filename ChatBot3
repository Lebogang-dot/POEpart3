    public partial class ProcessUserMessage : Window
    {
        private readonly ChatbotService _chatbotService;

        private readonly DatabaseHelper _databaseHelper;

        private readonly ActivityLogService _activityLogService;

        public ProcessUserMessage()
        {
            InitializeComponent();

            _databaseHelper = new DatabaseHelper();
            _activityLogService = new ActivityLogService();
            _chatbotService = new ChatbotService();


            btnSend.Click += BtnSend_Click;
            txtUserInput.KeyDown += TxtUserInput_KeyDown;

            InitializeApplication();
        }
        private void InitializeApplication()
        {
            txtDate.Text = DateTime.Now.ToString("dddd, dd MMMM yyyy");

            ShowWelcomeMessage();

            TestDatabaseConnection();

            _activityLogService.LogActivity("Application started.");


        }
        private void ShowWelcomeMessage()
        {
            AppendBotMessage(
@"Welcome to the CyberSecurity Awareness Chatbot!

I can help you with:

• Cybersecurity advice
• Password safety
• Phishing awareness
• Managing reminders
• Starting the cybersecurity quiz
• Viewing your activity log

Type 'help' to see available commands.");
        }
        private void TestDatabaseConnection()
        {
            try
            {
                using object connection = _databaseHelper.GetConnection();

                connection.Open();

                txtConnectionStatus.Text = "Database: Connected";
                txtApplicationStatus.Text = "Ready";
            }
            catch (Exception)
            {
                txtConnectionStatus.Text = "Database: Disconnected";
                txtApplicationStatus.Text = "Running without database";
            }
        }
        private void AppendBotMessage(string message)
        {
            Paragraph paragraph = new Paragraph();

            paragraph.Inlines.Add(
                new Bold(new Run("Bot: "))
            );

            paragraph.Inlines.Add(new Run(message));

            rtbChat.Document.Blocks.Add(paragraph);

            rtbChat.ScrollToEnd();
        }

        private void AppendUserMessage(string message)
        {
            Paragraph paragraph = new Paragraph();

            paragraph.Inlines.Add(
                new Bold(new Run("You: "))
            );

            paragraph.Inlines.Add(new Run(message));

            rtbChat.Document.Blocks.Add(paragraph);

            rtbChat.ScrollToEnd();
        }
        private void BtnSend_Click(object sender, RoutedEventArgs e)
        {
            ProcessUserMessage();
        }

        private void ProcessUserMessage()
        {
            throw new NotImplementedException();
        }

        private void TxtUserInput_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.Key == Key.Enter)
            {
                ProcessUserMessage();
                e.Handled = true;
            }
        }
