                throw new NotImplementedException();
            }
        }
        internal class ActivityLogService
        {
            internal void LogActivity(string v)
            {
                throw new NotImplementedException();
            }
        }
        internal class ChatbotService
        {
            public ChatbotService()
            {
            }
        }

        private ProcessUserMessage()
        {

            string userMessage = txtUserInput.Text.Trim();

            if (string.IsNullOrWhiteSpace(userMessage))
            {
                MessageBox.Show(
                    "Please enter a message before clicking Send.",
                    "Empty Message",
                    MessageBoxButton.OK,
                    MessageBoxImage.Information);

                return;
            }

            AppendUserMessage(userMessage);

            _activityLogService.LogActivity(
                $"User entered message: {userMessage}");

            txtUserInput.Clear();

            GenerateChatbotResponse(userMessage);
        }
        private void GenerateChatbotResponse(string message)
        {
            
            string sentiment = _sentimentService.DetectSentiment(message);

            string emotionResponse = _sentimentService.GetSentimentResponse(sentiment);

            if (!string.IsNullOrEmpty(emotionResponse))
            {
                AppendBotMessage(emotionResponse);
            }
            string input = message.ToLower();

            if (input.Contains("hello") ||
                input.Contains("hi") ||
                input.Contains("hey"))
            {
                AppendBotMessage(
                    "Hello!  I'm your Cybersecurity Awareness Assistant. How can I help you today?");

                return;
            }

            if (input.Contains("help"))
            {
                AppendBotMessage(

@"Here are some things you can ask me:

• Start Quiz

• Add Reminder

• Show Activity Log

• Password Tips

• Phishing Advice

• Safe Browsing

• Social Engineering

• Enable 2FA");

                return;
            }

            if (input.Contains("password"))
            {
                AppendBotMessage(

@"A strong password should:

 Be at least 12 characters long

 Include uppercase letters

 Include lowercase letters

 Include numbers

 Include special characters

Never reuse passwords on multiple websites.");

                return;
            }

            if (input.Contains("phishing"))
            {
                AppendBotMessage(

@"Phishing emails often:

• Ask for personal information

• Create urgency

• Contain suspicious links

• Have spelling mistakes

Always verify the sender before clicking links.");
                return;
            }

            if (input.Contains("safe browsing") ||
                input.Contains("browser"))
            {
                AppendBotMessage(

@"Safe browsing tips:

 Keep your browser updated

 Avoid suspicious websites

 Never download unknown files

 Check for HTTPS before entering passwords.");

                return;
            }
            if (input.Contains("2fa") ||
                input.Contains("two factor"))
            {
                AppendBotMessage(

@"Two-Factor Authentication adds an extra layer of security.

Even if someone steals your password, they still cannot access your account without the second verification step.");

                return;
            }
            if (input.Contains("reminder") ||
                input.Contains("remind"))
            {
                AppendBotMessage(

@"Opening the Reminder Manager...

Please enter:

Title

Description

Reminder Date");


                return;
            }

            if (input.Contains("quiz"))
            {
                AppendBotMessage(

@"Starting the Cybersecurity Quiz...

Good luck!");

                return;
            }

            if (input.Contains("activity"))
            {
                AppendBotMessage(

@"Opening your recent activity...

(Connected in ActivityLogService later)");

                return;
            }
            if (input.Contains("bye"))
            {
                AppendBotMessage(

@"Goodbye!

Stay safe online and remember to protect your personal information.");

                return;
            }
            AppendBotMessage(

@"Sorry, I didn't understand that.

Try asking me about:

• Passwords

• Phishing

• Safe Browsing

• Cyber Quiz

• Reminders

• Activity Log

or type 'Help'.");

            /// <summary>
            /// Creates a sample reminder.
            /// Later this will be replaced by a proper Reminder Window.
            /// </summary>
private void CreateReminder()
        {
            Reminder reminder = new Reminder
            {
                Title = "Enable Two-Factor Authentication",

                Description =
                "Enable 2FA on your email account.",

                ReminderDate =
                DateTime.Now.AddDays(2),

                Completed = false
            };

            bool success =
                _reminderService.AddReminder(reminder);

            if (success)
            {
                AppendBotMessage(

        @" Reminder Added Successfully!

Title:
Enable Two-Factor Authentication

Due:
" + reminder.ReminderDate.ToShortDateString());

                _activityLogService.LogActivity(
                    "Reminder Added");
            }
            else
            {
                AppendBotMessage(
                    " Unable to save reminder.");
            }
        }

        
